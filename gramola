  <title>Gramola Retro</title>
  <style>
    body {
      font-size: 12px;
	background: #FFFFFF;
      color: white;
      font-family: 'Courier New', monospace;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      margin: 0;
      padding: 20px;
    }

    .gramola {
      background: #e74c3c;
      border: 5px solid #c0392b;
      border-radius: 20px;
      padding: 20px;
      text-align: center;
      width: 340px;
      box-shadow: 0 0 15px rgba(0,0,0,0.5);
    }

    .gramola h2 {
      margin-top: 0;
    }

    .controls {
      margin: 15px 0;
    }

    .controls button {
      font-size: 12px;
	  background: #ecf0f1;
      border: none;
      padding: 10px 15px;
      margin: 0 5px;
      border-radius: 5px;
      cursor: pointer;
      font-weight: bold;
    }

    .controls button:hover {
      background: #bdc3c7;
    }

    audio {
      width: 70%;
      margin-top: 10px;
    }

    .playlist {
      font-size: 12px;
	  max-height: 70px;
      overflow-y: auto;
      margin-top: 15px;
      background: #ecf0f1;
      color: #2c3e50;
      border-radius: 10px;
      padding: 10px;
      text-align: left;
    }

    .playlist-item {
      padding: 6px 10px;
      border-radius: 5px;
      cursor: pointer;
    }

    .playlist-item:hover {
      background-color: #dcdcdc;
    }

    .playlist-item.active {
      background-color: #3498db;
      color: white;
      font-weight: bold;
    }
  </style>
</head>
